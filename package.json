    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "anchor-bankrun": "^0.5.0",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "sharp": "^0.34.5",
    "solana-bankrun": "^0.4.0",
    "ts-mocha": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
